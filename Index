                        <div className="modal-sub">Scan a friend's QR code to witness their eco-action and earn Karma.</div>
                        {!result && <>
                            <div style={{ border: '2px solid var(--border-glow)', borderRadius: 12, aspectRatio: '1', maxWidth: 200, margin: '16px auto', display: 'flex', alignItems: 'center', justifyContent: 'center', flexDirection: 'column', gap: 8, color: 'var(--text-muted)', fontSize: 13, background: 'var(--bg-card)' }}>
                                {scanning ? <>
                                    <div style={{ fontSize: 28, animation: 'spin-slow 1s linear infinite' }}>🔍</div>
                                    <div>Scanning...</div>
                                </> : <>
                                    <div style={{ fontSize: 28 }}>📱</div>
                                    <div>Camera View</div>
                                </>}
                            </div>
                            <button className="witness-btn" onClick={handleScan} disabled={scanning}>
                                {scanning ? 'Scanning...' : '🔍 Simulate QR Scan'}
                            </button>
                        </>}
                        {result && <>
                            <div style={{ background: 'var(--glow-green)', border: '1px solid var(--border-glow)', borderRadius: 12, padding: 16, textAlign: 'center', margin: '12px 0' }}>
                                <div style={{ fontSize: 24 }}>👀</div>
                                <div style={{ fontSize: 14, color: 'var(--text-primary)', fontWeight: 700, marginTop: 6 }}>Witness @{result.name}'s</div>
                                <div style={{ fontSize: 12, color: 'var(--text-secondary)' }}>{result.action}</div>
                                <div style={{ fontSize: 11, color: 'var(--accent-gold)', marginTop: 6 }}>+{result.xpReward} Karma for you</div>
                            </div>
                            <button className="witness-btn" onClick={handleWitness}>✅ Confirm Witness</button>
                        </>}
                    </div>
                </div>
            );
        }

        // ── MAIN APP ──────────────────────────────────────────────────────────────
        function App() {
            const [profile, setProfile] = useState(loadProfile);
            const [tab, setTab] = useState('home');
            const [ecoAnimKey, setEcoAnimKey] = useState(0);
            const [showTale, setShowTale] = useState(false);
            const [showScan, setShowScan] = useState(false);
            const [toast, setToast] = useState(null);
            const [isDesktopMode, setIsDesktopMode] = useState(false);

            // Streak logic on load
            useEffect(() => {
                const p = loadProfile();
                const now = new Date();
                if (p.lastLogDate) {
                    const last = new Date(p.lastLogDate);
                    const diffDays = Math.floor((now - last) / 86400000);
                    if (diffDays > 1) {
                        p.streak = 0;
                        p.stats = { agility: Math.max(0, p.stats.agility - 2), vitality: Math.max(0, p.stats.vitality - 2), purity: Math.max(0, p.stats.purity - 2), wealth: Math.max(0, p.stats.wealth - 2) };
                        setProfile({ ...p });
                        saveProfile(p);
                        showToastMsg('Stat decay applied — log today to prevent further withering.', '🌫️');
                    }
                }
            }, []);

            const showToastMsg = (msg, icon) => {
                setToast({ msg, icon });
                setTimeout(() => setToast(null), 3500);
            };

            const handleLog = useCallback((type, positive, xpGain, photoHash, callback) => {
                setProfile(prev => {
                    const now = new Date().toISOString().split('T')[0];
                    const newStats = { ...prev.stats };
                    let newDebt = prev.carbonDebt;

                    if (positive) {
                        newStats[type] = Math.min(100, newStats[type] + (type === 'agility' ? 8 : type === 'wealth' ? 6 : 10));
                        newDebt = Math.max(0, newDebt - 5);
                    } else {
                        newStats[type] = Math.max(0, newStats[type] - 12);
                        newDebt = Math.min(100, newDebt + 10);
                    }

                    // Check streak
                    let newStreak = prev.streak;
                    const lastLog = prev.lastLogDate;
                    if (lastLog !== now) {
                        const last = lastLog ? new Date(lastLog) : null;
                        const today = new Date(now);
                        const diffDays = last ? Math.floor((today - last) / 86400000) : 999;
                        newStreak = diffDays === 1 ? newStreak + 1 : 1;
                    }

                    const newXP = positive ? prev.xp + xpGain : prev.xp;

                    // Update trust tier
                    const actionLog = loadActionLog();
                    const witnessed = actionLog.filter(a => a.witnessed).length;
                    const total = actionLog.length + 1;
                    const trustTier = (witnessed / total) > 0.5 ? 'high' : witnessed > 0 ? 'peer' : 'self';

                    const newProfile = {
                        ...prev, stats: newStats, xp: newXP,
                        lastLogDate: now, streak: newStreak,
                        carbonDebt: newDebt, trustTier,
                        level: getLevelFromXP(newXP),
                    };

                    saveProfile(newProfile);

                    // Save action log
                    const newLog = [{ id: uuid(), timestamp: new Date().toISOString(), type, value: newStats[type], witnessed: false, photoHash }, ...actionLog.slice(0, 49)];
                    saveActionLog(newLog);

                    setEcoAnimKey(k => k + 1);

                    callback({ xpGained: xpGain });
                    return newProfile;
                });
            }, []);

            const handleWitness = useCallback((karmaGain) => {
                setProfile(prev => {
                    const newProfile = { ...prev, karma: prev.karma + karmaGain };
                    saveProfile(newProfile);
                    showToastMsg(`+${karmaGain} Karma earned for witnessing! ✨`, '👀');
                    return newProfile;
                });
            }, []);

            return (
                <div className={`app-shell${isDesktopMode ? ' desktop-mode' : ''}`}>
                    <Header profile={profile} onScan={() => setShowScan(true)} isDesktopMode={isDesktopMode} toggleMode={() => setIsDesktopMode(!isDesktopMode)} />

                    {tab === 'home' && <HomeScreen profile={profile} animKey={ecoAnimKey} onTale={() => setShowTale(true)} />}
                    {tab === 'log' && <LogScreen profile={profile} onLog={handleLog} />}
                    {tab === 'leaderboard' && <LeaderboardScreen profile={profile} />}

                    <div className="bottom-nav">
                        {[
                            { id: 'home', icon: '🏠', label: 'Sanctuary' },
                            { id: 'log', icon: '📝', label: 'Log' },
                            { id: 'leaderboard', icon: '🏆', label: 'Rankings' },
                        ].map(t => (
                            <button key={t.id} className={`nav-btn${tab === t.id ? ' active' : ''}`} onClick={() => setTab(t.id)}>
                                <span>{t.icon}</span>
                                <span>{t.label}</span>
                            </button>
                        ))}
                    </div>

                    {toast && <Toast msg={toast.msg} icon={toast.icon} />}
                    {showTale && <TaleModal profile={profile} onClose={() => setShowTale(false)} />}
                    {showScan && <ScanModal onClose={() => setShowScan(false)} onWitness={handleWitness} />}
                </div>
            );
        }

        ReactDOM.createRoot(document.getElementById('root')).render(<App />);
    </script>
</body>

</html>
