                                    <div style={{ border: '2px solid var(--border-glow)', borderRadius: 12, aspectRatio: '1', maxWidth: 200, margin: '16px auto', display: 'flex', alignItems: 'center', justifyContent: 'center', flexDirection: 'column', gap: 8, color: 'var(--text-muted)', fontSize: 13, background: 'var(--bg-card)' }}>
                                        {scanningQR ? <>
                                            <div style={{ fontSize: 28, animation: 'spin-slow 1s linear infinite' }}>🔍</div>
                                            <div>Scanning...</div>
                                        </> : <>
                                            <div style={{ fontSize: 28 }}>📱</div>
                                            <div>Camera View</div>
                                        </>}
                                    </div>

                                    <button className="simulate-witness-btn" onClick={() => {
                                        setScanningQR(true);
                                        setTimeout(() => {
                                            setScanningQR(false);
                                            const xpGain = 15;
                                            onLog(modal.type, true, xpGain, null, (result) => {
                                                if (result.toastMsg) showToast(result.toastMsg, result.toastIcon);
                                                else setModal({ type: modal.type, step: 'success', xpGained: result.xpGained, witnessed: false, firstDiscovery: false });
                                            });
                                        }, 1500);
                                    }} disabled={scanningQR}>
                                        {scanningQR ? 'Scanning...' : '🧪 Simulate Scanner (Demo)'}
                                    </button>
                                </>}

                                {modal.step === 'analyzing' && <>
                                    <div className="modal-title">🔬 AI Analyzing...</div>
                                    <div className="modal-sub">Our model is verifying your eco-action. Just a moment.</div>
                                    <div style={{ textAlign: 'center', padding: '20px 0', fontSize: 40 }}>🌿</div>
                                    <div style={{ fontSize: 12, color: 'var(--text-muted)', textAlign: 'center', marginBottom: 8 }}>Checking for plant-based content...</div>
                                    <div className="analyzing-bar"><div className="analyzing-fill" /></div>
                                </>}

                                {modal.step === 'success' && <>
                                    <div style={{ textAlign: 'center', padding: '12px 0 8px' }}>
                                        <div style={{ fontSize: 48, animation: 'bloom 0.5s ease' }}>✅</div>
                                        <div className="modal-title" style={{ marginTop: 8, textAlign: 'center' }}>Action Logged!</div>
                                        <div style={{ fontSize: 13, color: 'var(--text-secondary)', textAlign: 'center', marginTop: 4 }}>
                                            +{modal.xpGained} XP earned
                                            {modal.firstDiscovery && <span style={{ color: 'var(--accent-gold)' }}> · ⭐ First Discovery +5</span>}
                                        </div>
                                    </div>
                                    <div className="witness-box">
                                        <div style={{ fontSize: 12, color: 'var(--text-muted)', marginBottom: 4 }}>Earn +10% bonus XP & boost your Trust Tier</div>
                                        {!modal.witnessed ? <>
                                            <button className="witness-btn" onClick={() => setModal(m => ({ ...m, step: 'witness' }))}>
                                                👥 Ask a Friend to Witness (+10% XP)
                                            </button>
                                        </> : (
                                            <div style={{ color: 'var(--accent-green)', fontWeight: 700, fontSize: 13 }}>👀 Action Witnessed! XP Bonus Applied.</div>
                                        )}
                                    </div>
                                    <button className="witness-btn" style={{ marginTop: 12, background: 'transparent', border: '1px solid var(--border)', color: 'var(--text-muted)' }}
                                        onClick={() => setModal(null)}>Done</button>
                                </>}

                                {modal.step === 'witness' && <>
                                    <div className="modal-title">👀 Witness QR Code</div>
                                    <div className="modal-sub">Have a friend scan this with their CARBON RPG app.</div>
                                    <div className="qr-mock" />
                                    <div style={{ textAlign: 'center', fontSize: 11, color: 'var(--text-muted)', fontFamily: 'monospace', marginBottom: 12 }}>
                                        CRPG-{uuid().toUpperCase()}
