<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CARBON RPG — The Ephemeral Ecosystem</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
        rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
    <style>
        :root {
            --bg-deep: #0a0f0d;
            --bg-mid: #111a14;
            --bg-card: #162018;
            --bg-card2: #1a2a1e;
            --border: #2a3d2e;
            --border-glow: #3d6645;
            --text-primary: #d4e8d0;
            --text-secondary: #7a9e80;
            --text-muted: #4a6650;
            --accent-green: #4eca6e;
            --accent-gold: #d4a843;
            --accent-blue: #4ab8ca;
            --accent-red: #ca5a4e;
            --accent-purple: #9b72ca;
            --glow-green: rgba(78, 202, 110, 0.15);
            --glow-gold: rgba(212, 168, 67, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 100%;
            height: 100%;
            background: #0a0f0d;
            overflow: hidden;
        }

        #root {
            width: 100%;
            height: 100%;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0)
            }

            50% {
                transform: translateY(-6px)
            }
        }

        @keyframes pulse-glow {

            0%,
            100% {
                opacity: 0.6
            }

            50% {
                opacity: 1
            }
        }

        @keyframes spin-slow {
            from {
                transform: rotate(0deg)
            }

            to {
                transform: rotate(360deg)
            }
        }

        @keyframes spin-turbine {
            from {
                transform-origin: center;
                transform: rotate(0deg)
            }

            to {
                transform-origin: center;
                transform: rotate(360deg)
            }
        }

        @keyframes bloom {
            0% {
                transform: scale(0) rotate(-20deg);
                opacity: 0
            }

            60% {
                transform: scale(1.2) rotate(5deg)
            }

            100% {
                transform: scale(1) rotate(0deg);
                opacity: 1
            }
        }

        @keyframes stream-flow {
            0% {
                stroke-dashoffset: 200
            }

            100% {
                stroke-dashoffset: 0
            }
        }

        @keyframes mote-rise {
            0% {
                transform: translateY(0) scale(1);
                opacity: 0.9
            }

            100% {
                transform: translateY(-40px) scale(0);
                opacity: 0
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(16px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes shimmer {
            0% {
                background-position: 200% center
            }

            100% {
                background-position: -200% center
            }
        }

        @keyframes debt-pulse {

            0%,
            100% {
                opacity: 0.18
            }

            50% {
                opacity: 0.32
            }
        }

        @keyframes toast-in {
            from {
                opacity: 0;
                transform: translateX(-50%) translateY(20px)
            }

            to {
                opacity: 1;
                transform: translateX(-50%) translateY(0)
            }
        }

        @keyframes xp-fill {
            from {
                width: 0%
            }

            to {
                width: var(--xp-pct)
            }
        }

        @keyframes ripple {
            0% {
                transform: scale(0);
                opacity: 0.6
            }

            100% {
                transform: scale(3);
                opacity: 0
            }
        }

        @keyframes blink-star {

            0%,
            100% {
                opacity: 0.3;
                transform: scale(0.8)
            }

            50% {
                opacity: 1;
                transform: scale(1.2)
            }
        }

        .app-shell {
            display: flex;
            flex-direction: column;
            height: 100vh;
            max-width: 480px;
            margin: 0 auto;
            background: var(--bg-deep);
            position: relative;
            overflow: hidden;
            font-family: 'Lato', sans-serif;
        }

        .header {
            padding: 12px 16px 8px;
            background: linear-gradient(180deg, rgba(10, 15, 13, 0.98) 0%, rgba(10, 15, 13, 0.9) 100%);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px);
            flex-shrink: 0;
            z-index: 10;
        }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .header-title {
            font-family: 'Cinzel', serif;
            font-size: 11px;
            letter-spacing: 3px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .header-meta {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .streak-badge {
            font-size: 12px;
            font-weight: 700;
            color: var(--accent-gold);
            display: flex;
            align-items: center;
            gap: 3px;
            background: rgba(212, 168, 67, 0.12);
            padding: 3px 8px;
            border-radius: 20px;
            border: 1px solid rgba(212, 168, 67, 0.25);
        }

        .karma-badge {
            font-size: 12px;
            font-weight: 700;
            color: var(--accent-purple);
            display: flex;
            align-items: center;
            gap: 3px;
            background: rgba(155, 114, 202, 0.12);
            padding: 3px 8px;
            border-radius: 20px;
            border: 1px solid rgba(155, 114, 202, 0.25);
        }

        .scan-btn {
            background: rgba(78, 202, 110, 0.12);
            border: 1px solid rgba(78, 202, 110, 0.3);
            color: var(--accent-green);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            cursor: pointer;
            font-family: 'Lato', sans-serif;
            transition: all 0.2s;
        }

        .scan-btn:hover {
            background: rgba(78, 202, 110, 0.22);
        }

        .xp-bar-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .level-badge {
            font-family: 'Cinzel', serif;
            font-size: 13px;
            font-weight: 700;
            color: var(--accent-green);
            white-space: nowrap;
            background: var(--glow-green);
            padding: 2px 8px;
            border-radius: 4px;
            border: 1px solid rgba(78, 202, 110, 0.3);
        }

        .xp-bar-bg {
            flex: 1;
            height: 6px;
            background: #1a2a1e;
            border-radius: 3px;
            overflow: hidden;
        }

        .xp-bar-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, #2a8c4e, #4eca6e, #8aeea8);
            background-size: 200% 100%;
            animation: shimmer 2s linear infinite;
            transition: width 0.8s cubic-bezier(.34, 1.56, .64, 1);
        }

        .xp-label {
            font-size: 10px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .tab-content {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-bottom: 70px;
        }

        .tab-content::-webkit-scrollbar {
            width: 3px;
        }

        .tab-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .tab-content::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 2px;
        }

        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 480px;
            background: rgba(10, 15, 13, 0.97);
            border-top: 1px solid var(--border);
            display: flex;
            backdrop-filter: blur(20px);
            z-index: 20;
        }

        .nav-btn {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px 4px 14px;
            cursor: pointer;
            border: none;
            background: none;
            color: var(--text-muted);
            font-family: 'Lato', sans-serif;
            transition: all 0.25s;
            position: relative;
        }

        .nav-btn.active {
            color: var(--accent-green);
        }

        .nav-btn.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 2px;
            background: var(--accent-green);
            border-radius: 2px 2px 0 0;
            box-shadow: 0 0 8px var(--accent-green);
        }

        .nav-btn span:first-child {
            font-size: 20px;
            margin-bottom: 2px;
        }

        .nav-btn span:last-child {
            font-size: 9px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 700;
        }

        /* ECOSYSTEM */
        .ecosystem-wrap {
            position: relative;
            width: 100%;
            aspect-ratio: 16/9;
            overflow: hidden;
        }

        .eco-svg {
            width: 100%;
            height: 100%;
        }

        .eco-score-overlay {
            position: absolute;
            bottom: 12px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(10, 15, 13, 0.8);
            border: 1px solid var(--border-glow);
            border-radius: 20px;
            padding: 4px 16px;
            font-family: 'Cinzel', serif;
            font-size: 11px;
            color: var(--accent-green);
            letter-spacing: 2px;
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .eco-state-name {
            color: var(--text-muted);
            font-size: 9px;
            letter-spacing: 3px;
        }

        /* HOME CARDS */
        .home-section {
            padding: 16px;
        }

        .section-title {
            font-family: 'Cinzel', serif;
            font-size: 10px;
            letter-spacing: 3px;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 12px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transition: all 0.3s;
        }

        .stat-card:hover {
            border-color: var(--border-glow);
        }

        .stat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-name {
            font-size: 10px;
            letter-spacing: 2px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .stat-icon {
            font-size: 16px;
        }

        .stat-value {
            font-family: 'Cinzel', serif;
            font-size: 22px;
            font-weight: 700;
        }

        .stat-bar-bg {
            height: 4px;
            background: #1a2a1e;
            border-radius: 2px;
            overflow: hidden;
        }

        .stat-bar-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 0.8s cubic-bezier(.34, 1.56, .64, 1);
        }

        .class-badge {
            background: var(--bg-card2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 16px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .class-icon {
            font-size: 32px;
            animation: float 4s ease-in-out infinite;
        }

        .class-info {
            flex: 1;
        }

        .class-label {
            font-size: 10px;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .class-name {
            font-family: 'Cinzel', serif;
            font-size: 18px;
            color: var(--text-primary);
            margin-top: 2px;
        }

        .class-sub {
            font-size: 11px;
            color: var(--text-secondary);
            margin-top: 3px;
        }

        .tale-btn {
            width: 100%;
            background: linear-gradient(135deg, rgba(26, 42, 30, 0.8), rgba(22, 32, 24, 0.8));
            border: 1px solid var(--border-glow);
            border-radius: 12px;
            padding: 14px;
            color: var(--text-secondary);
            font-family: 'Lato', sans-serif;
            font-size: 13px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s;
            letter-spacing: 0.5px;
        }

        .tale-btn:hover {
            color: var(--accent-gold);
            border-color: rgba(212, 168, 67, 0.4);
            background: rgba(212, 168, 67, 0.06);
        }

        /* LOG SCREEN */
        .log-cards {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .log-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 18px;
            overflow: hidden;
            transition: all 0.3s;
        }

        .log-card:hover {
            border-color: var(--border-glow);
        }

        .log-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .log-stat-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .log-stat-icon {
            font-size: 24px;
        }

        .log-stat-name {
            font-family: 'Cinzel', serif;
            font-size: 14px;
            color: var(--text-primary);
        }

        .log-stat-val {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .log-stat-current {
            font-family: 'Cinzel', serif;
            font-size: 20px;
            font-weight: 600;
        }

        .log-primary-btn {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            font-family: 'Lato', sans-serif;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: all 0.25s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            position: relative;
            overflow: hidden;
        }

        .log-primary-btn::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            transform: scale(0);
            transition: transform 0.4s;
        }

        .log-primary-btn:active::after {
            animation: ripple 0.4s ease-out;
        }

        .log-secondary-btn {
            width: 100%;
            margin-top: 8px;
            padding: 8px;
            border-radius: 8px;
            background: transparent;
            border: 1px solid rgba(202, 90, 78, 0.2);
            color: rgba(202, 90, 78, 0.7);
            font-family: 'Lato', sans-serif;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.25s;
            letter-spacing: 0.5px;
        }

        .log-secondary-btn:hover {
            border-color: rgba(202, 90, 78, 0.5);
            color: var(--accent-red);
            background: rgba(202, 90, 78, 0.05);
        }

        /* LEADERBOARD */
        .leaderboard-wrap {
            padding: 16px;
        }

        .lb-filter {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        .lb-filter-btn {
            flex: 1;
            padding: 8px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-muted);
            font-family: 'Lato', sans-serif;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 0.5px;
        }

        .lb-filter-btn.active {
            border-color: var(--accent-green);
            color: var(--accent-green);
            background: var(--glow-green);
        }

        .lb-entry {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-bottom: 8px;
            transition: all 0.3s;
            animation: fadeInUp 0.4s ease both;
        }

        .lb-entry.is-user {
            border-color: var(--border-glow);
            background: var(--bg-card2);
        }

        .lb-rank {
            font-family: 'Cinzel', serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--text-muted);
            width: 28px;
        }

        .lb-rank.gold {
            color: var(--accent-gold);
        }

        .lb-rank.silver {
            color: #c0c0c0;
        }

        .lb-rank.bronze {
            color: #cd7f32;
        }

        .lb-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            background: var(--bg-mid);
            border: 1px solid var(--border);
        }

        .lb-info {
            flex: 1;
        }

        .lb-name {
            font-size: 13px;
            color: var(--text-primary);
            font-weight: 700;
        }

        .lb-class {
            font-size: 10px;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        .lb-score {
            font-family: 'Cinzel', serif;
            font-size: 16px;
            color: var(--accent-green);
        }

        .lb-trust {
            font-size: 14px;
        }

        /* MODAL */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            backdrop-filter: blur(8px);
            animation: fadeInUp 0.2s ease;
        }

        .modal-box {
            background: var(--bg-mid);
            border: 1px solid var(--border-glow);
            border-radius: 20px;
            padding: 24px;
            width: 100%;
            max-width: 420px;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 0 60px rgba(78, 202, 110, 0.1);
            animation: fadeInUp 0.3s cubic-bezier(.34, 1.56, .64, 1);
        }

        .modal-title {
            font-family: 'Cinzel', serif;
            font-size: 18px;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .modal-sub {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 16px;
        }

        .modal-close:hover {
            color: var(--text-primary);
            border-color: var(--border-glow);
        }

        /* TOAST */
        .toast {
            position: fixed;
            bottom: 85px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-card2);
            border: 1px solid var(--border-glow);
            border-radius: 12px;
            padding: 10px 18px;
            font-size: 13px;
            color: var(--text-primary);
            z-index: 200;
            white-space: nowrap;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
            animation: toast-in 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* QR mock */
        .qr-mock {
            width: 120px;
            height: 120px;
            margin: 16px auto;
            background: repeating-conic-gradient(var(--bg-card) 0% 25%, var(--accent-green) 0% 50%) 0 0/8px 8px;
            border: 3px solid var(--accent-green);
            border-radius: 8px;
            opacity: 0.8;
        }

        /* ANALYZING */
        .analyzing-bar {
            width: 100%;
            height: 3px;
            background: var(--bg-card);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 12px;
        }

        .analyzing-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-green));
            border-radius: 2px;
            animation: shimmer 1s linear infinite;
            background-size: 200% 100%;
            width: 60%;
            animation: analyzing-move 2s ease-in-out forwards;
        }

        @keyframes analyzing-move {
            0% {
                width: 5%
            }

            70% {
                width: 85%
            }

            100% {
                width: 100%
            }
        }

        /* TALE MODAL */
        .tale-bg {
            background: linear-gradient(135deg, #0d1f12, #102018, #0d1a15);
            border: 1px solid var(--border-glow);
            border-radius: 16px;
            padding: 20px;
            margin-top: 12px;
            position: relative;
            overflow: hidden;
        }

        .tale-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(78, 202, 110, 0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 50%, rgba(74, 184, 202, 0.06) 0%, transparent 60%);
        }

        .tale-text {
            font-family: 'Lato', sans-serif;
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.8;
            position: relative;
            font-style: italic;
            letter-spacing: 0.3px;
        }

        .tale-highlight {
            color: var(--accent-green);
            font-style: normal;
            font-weight: 700;
        }

        /* DEBT SHADOW */
        .debt-shadow {
            animation: debt-pulse 3s ease-in-out infinite;
        }

        /* WITNESS SUCCESS */
        .witness-box {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            margin-top: 12px;
        }

        .witness-btn {
            width: 100%;
            padding: 11px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg, #1a3d28, #2a5a3e);
            border: 1px solid rgba(78, 202, 110, 0.3);
            color: var(--accent-green);
            font-family: 'Lato', sans-serif;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .witness-btn:hover {
            background: linear-gradient(135deg, #1f4a30, #326b4a);
        }

        .simulate-witness-btn {
            width: 100%;
            padding: 9px;
            border-radius: 8px;
            border: 1px dashed var(--border-glow);
            background: transparent;
            color: var(--text-muted);
            font-family: 'Lato', sans-serif;
            font-size: 11px;
            cursor: pointer;
            margin-top: 6px;
            transition: all 0.2s;
        }

        .simulate-witness-btn:hover {
            color: var(--text-secondary);
            border-color: var(--text-muted);
        }

        /* MOTES */
        .mote {
            position: absolute;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--accent-gold);
            animation: mote-rise 2s ease-out forwards;
            pointer-events: none;
        }

        /* File upload */
        .file-upload-area {
            border: 1.5px dashed var(--border-glow);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 10px;
            background: rgba(78, 202, 110, 0.03);
        }

        .file-upload-area:hover {
            background: rgba(78, 202, 110, 0.06);
        }

        .file-upload-area input {
            display: none;
        }

        /* STARS */
        .star {
            position: absolute;
            border-radius: 50%;
            background: white;
            animation: blink-star 3s ease-in-out infinite;
        }

        /* ── DESKTOP MODE (PREMIUM LAYOUT) ── */
        .app-shell.desktop-mode {
            max-width: 100vw;
            height: 100vh;
            display: grid;
            grid-template-columns: 280px 1fr;
            grid-template-rows: auto 1fr;
            grid-template-areas:
                "nav header"
                "nav content";
            background: #0a0f0d;
        }

        .app-shell.desktop-mode .header {
            grid-area: header;
            padding: 20px 40px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent;
            backdrop-filter: none;
        }

        .app-shell.desktop-mode .header-title {
            font-size: 18px;
            letter-spacing: 4px;
        }

        .app-shell.desktop-mode .streak-badge,
        .app-shell.desktop-mode .karma-badge {
            padding: 6px 14px;
            font-size: 14px;
        }

        .app-shell.desktop-mode .scan-btn {
            padding: 8px 16px;
            font-size: 13px;
        }

        .app-shell.desktop-mode .bottom-nav {
            grid-area: nav;
            position: static;
            transform: none;
            width: 100%;
            max-width: none;
            flex-direction: column;
            justify-content: flex-start;
            padding-top: 40px;
            border-top: none;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            background: #101612;
            box-shadow: 2px 0 30px rgba(0, 0, 0, 0.6);
        }

        .app-shell.desktop-mode .nav-btn {
            flex: none;
            flex-direction: row;
            justify-content: flex-start;
            padding: 20px 30px;
            margin: 8px 24px;
            border-radius: 16px;
            gap: 20px;
            height: auto;
        }

        .app-shell.desktop-mode .nav-btn:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .app-shell.desktop-mode .nav-btn.active {
            background: rgba(78, 202, 110, 0.08);
            border: 1px solid rgba(78, 202, 110, 0.2);
        }

        .app-shell.desktop-mode .nav-btn.active::after {
            display: none;
        }

        .app-shell.desktop-mode .nav-btn span:first-child {
            font-size: 26px;
            margin-bottom: 0;
        }

        .app-shell.desktop-mode .nav-btn span:last-child {
            font-size: 14px;
            letter-spacing: 2.5px;
        }

        .app-shell.desktop-mode .tab-content {
            grid-area: content;
            padding-bottom: 0;
        }

        /* Home Split-Pane Layout */
        .app-shell.desktop-mode .tab-content.home-view {
            display: grid;
            grid-template-columns: 1fr 440px;
            height: 100%;
            overflow: hidden;
        }

        .app-shell.desktop-mode .ecosystem-wrap {
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            height: 100%;
            aspect-ratio: unset;
            background: #050806;
        }

        .app-shell.desktop-mode .eco-svg {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .app-shell.desktop-mode .eco-score-overlay {
            bottom: 50px;
            padding: 14px 34px;
            font-size: 20px;
            border-radius: 40px;
            backdrop-filter: blur(12px);
        }

        .app-shell.desktop-mode .eco-state-name {
            font-size: 13px;
            letter-spacing: 4px;
        }

        .app-shell.desktop-mode .home-section {
            background: #0d120f;
            padding: 40px 32px;
            overflow-y: auto;
            height: 100%;
            box-shadow: inset 10px 0 40px rgba(0, 0, 0, 0.3);
            border-left: 1px solid black;
        }

        /* Component Refinements for Desktop */
        .app-shell.desktop-mode .class-badge {
            padding: 30px;
            gap: 24px;
            margin-bottom: 24px;
            border-radius: 16px;
            background: rgba(26, 42, 30, 0.4);
        }

        .app-shell.desktop-mode .class-icon {
            font-size: 48px;
        }

        .app-shell.desktop-mode .class-label {
            font-size: 12px;
        }

        .app-shell.desktop-mode .class-name {
            font-size: 24px;
            margin-top: 4px;
        }

        .app-shell.desktop-mode .class-sub {
            font-size: 13px;
            margin-top: 6px;
        }

        .app-shell.desktop-mode .section-title {
            font-size: 12px;
            margin-bottom: 20px;
        }

        .app-shell.desktop-mode .stats-grid {
            gap: 16px;
            margin-bottom: 32px;
        }

        .app-shell.desktop-mode .stat-card {
            padding: 22px 20px;
            border-radius: 16px;
            background: #131a15;
        }

        .app-shell.desktop-mode .stat-name {
            font-size: 12px;
        }

        .app-shell.desktop-mode .stat-value {
            font-size: 28px;
        }

        .app-shell.desktop-mode .tale-btn {
            padding: 20px;
            font-size: 15px;
            border-radius: 16px;
            margin-top: 24px;
        }

        /* Log & Leaderboard Grids */
        .app-shell.desktop-mode .log-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
            gap: 24px;
            padding: 40px 60px;
        }

        .app-shell.desktop-mode .leaderboard-wrap {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 60px;
        }

        .app-shell.desktop-mode .lb-entry {
            padding: 20px 24px;
            margin-bottom: 12px;
            font-size: 15px;
        }

        .app-shell.desktop-mode .lb-avatar {
            width: 44px;
            height: 44px;
            font-size: 22px;
        }
    </style>
</head>

<body>
    <div id="root"></div>
    <script type="text/babel">
        const { useState, useEffect, useRef, useCallback } = React;

        // ── CONSTANTS ─────────────────────────────────────────────────────────────
        const STAT_CONFIGS = {
            agility: { label: 'Agility', icon: '🏃', color: '#4eca6e', colorDark: '#2a8c4e', description: 'Movement & Transport', primary: '🚶 Log Walk / Cycle', secondary: '...or took a car / flight?', requiresImage: false },
            vitality: { label: 'Vitality', icon: '🌿', color: '#82ca6e', colorDark: '#4a8c3e', description: 'Food & Nourishment', primary: '🥗 Log Plant-Based Meal', secondary: '...or ate meat / processed food?', requiresImage: true },
            purity: { label: 'Purity', icon: '💧', color: '#4ab8ca', colorDark: '#2a7a8c', description: 'Waste & Energy', primary: '♻️ Log Recycle / Green Energy', secondary: '...or wasted energy / no recycling?', requiresImage: true },
            wealth: { label: 'Wealth', icon: '🌱', color: '#d4a843', colorDark: '#8c6a1e', description: 'Consumption & Shopping', primary: '🛒 Log Sustainable Purchase', secondary: '...or bought fast fashion / excess?', requiresImage: false },
        };

        const ECO_STATES = [
            { min: 0, max: 19, name: 'The Ashen Expanse', color: '#3a3d3a' },
            { min: 20, max: 39, name: 'The Sprouting', color: '#2d5c35' },
            { min: 40, max: 59, name: 'The Flourishing', color: '#3a7a44' },
            { min: 60, max: 79, name: 'The Verdant Realm', color: '#4a9a58' },
            { min: 80, max: 100, name: 'The Luminous Sanctuary', color: '#5aba6e' },
        ];

        const CLASS_DATA = {
            agility: { name: 'The Ranger', icon: '🏹', desc: 'Swift and untethered, you tread lightly.' },
            vitality: { name: 'The Cultivator', icon: '🌾', desc: 'Nourished by the earth, you grow deeply.' },
            purity: { name: 'The Purifier', icon: '🌊', desc: 'Clear as water, you cleanse what is tainted.' },
            wealth: { name: 'The Merchant of Green', icon: '⚖️', desc: 'Every choice a vote for the world you want.' },
            default: { name: 'The Ember', icon: '🔥', desc: 'A spark seeking its element.' },
        };

        const MOCK_LEADERBOARD = [
            { id: 'u2', name: 'GreenSage', score: 88, trustTier: 'high', class: 'agility', karma: 340 },
            { id: 'u3', name: 'PureRoot', score: 74, trustTier: 'peer', class: 'purity', karma: 210 },
            { id: 'u4', name: 'WildHarvest', score: 61, trustTier: 'peer', class: 'vitality', karma: 180 },
            { id: 'u5', name: 'SilverStream', score: 48, trustTier: 'self', class: 'wealth', karma: 45 },
            { id: 'u6', name: 'DuskWatcher', score: 22, trustTier: 'self', class: 'agility', karma: 12 },
        ];

        const TALE_NARRATIVES = {
            agility: ['Your feet have written a story across the earth this week.', 'Every step was a vote for a greener tomorrow.'],
            vitality: ['The garden answered your choices with abundance.', 'Each plant-based meal fed the roots of your world.'],
            purity: ['Clean hands, clear streams—you filtered the world around you.', 'Your discipline turned chaos into clarity.'],
            wealth: ['Thoughtful hands touched lightly what they held.', 'You chose sufficiency over surplus.'],
        };

        function uuid() { return Math.random().toString(36).slice(2, 9); }
        function getEcoState(score) { return ECO_STATES.find(s => score >= s.min && score <= s.max) || ECO_STATES[0]; }
        function getEcoScore(stats) { return Math.round((stats.agility + stats.vitality + stats.purity + stats.wealth) / 4); }
        function getHighestStat(stats) { return Object.entries(stats).sort((a, b) => b[1] - a[1])[0][0]; }
        function getLowestStat(stats) { return Object.entries(stats).sort((a, b) => a[1] - b[1])[0][0]; }
        function getClass(stats) { const h = getHighestStat(stats); return stats[h] > 35 ? CLASS_DATA[h] : CLASS_DATA.default; }
        function getTrustIcon(tier) { return tier === 'high' ? '🛡️' : tier === 'peer' ? '👀' : '📝'; }
        function getLevelFromXP(xp) { return Math.floor(xp / 100) + 1; }
        function getXPProgress(xp) { return ((xp % 100) / 100) * 100; }

        // ── LOCAL STORAGE ─────────────────────────────────────────────────────────
        const DEFAULT_PROFILE = {
            id: 'local_user_1', name: 'EcoWarrior', level: 1, xp: 0, karma: 0, streak: 0,
            lastLogDate: null, carbonDebt: 20,
            stats: { agility: 30, vitality: 30, purity: 30, wealth: 30 },
            class: 'Ember', trustTier: 'self', witnessedCount: 0,
        };

        function loadProfile() {
            try { const p = localStorage.getItem('crpg_profile'); return p ? JSON.parse(p) : DEFAULT_PROFILE; }
            catch { return DEFAULT_PROFILE; }
        }
        function saveProfile(p) { localStorage.setItem('crpg_profile', JSON.stringify(p)); }
        function loadActionLog() {
            try { const l = localStorage.getItem('crpg_actions'); return l ? JSON.parse(l) : []; }
            catch { return []; }
        }
        function saveActionLog(l) { localStorage.setItem('crpg_actions', JSON.stringify(l)); }
        function loadPhotoHashes() {
            try { const h = localStorage.getItem('crpg_hashes'); return h ? JSON.parse(h) : {}; }
            catch { return {}; }
        }
        function savePhotoHashes(h) { localStorage.setItem('crpg_hashes', JSON.stringify(h)); }

        // ── ECOSYSTEM SVG ─────────────────────────────────────────────────────────
        function Ecosystem({ ecoScore, hasDebt, animKey }) {
            const state = getEcoState(ecoScore);
            const level = ECO_STATES.indexOf(state);

            const stars = Array.from({ length: 18 }, (_, i) => ({
                x: Math.sin(i * 137.5) * 45 + 50, y: Math.cos(i * 97.3) * 30 + 25,
                r: Math.random() * 1.2 + 0.4, delay: Math.random() * 3
            }));

            return (
                <svg viewBox="0 0 400 225" className="eco-svg" key={animKey}>
                    <defs>
                        <radialGradient id="sky-grad" cx="50%" cy="0%" r="100%">
                            <stop offset="0%" stopColor={level >= 4 ? "#0a2028" : level >= 3 ? "#0a1a20" : level >= 2 ? "#0a1820" : level >= 1 ? "#141810" : "#1a1a1a"} />
                            <stop offset="100%" stopColor={level >= 4 ? "#051510" : level >= 3 ? "#051210" : level >= 2 ? "#050f0a" : "#0a0a0a"} />
                        </radialGradient>
                        <radialGradient id="sun-grad" cx="50%" cy="50%" r="50%">
                            <stop offset="0%" stopColor={level >= 4 ? "#ffe87a" : level >= 2 ? "#ffd060" : "#ffb030"} stopOpacity="0.9" />
                            <stop offset="100%" stopColor="transparent" />
                        </radialGradient>
                        <linearGradient id="ground-grad" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stopColor={level >= 3 ? "#2a5c30" : level >= 2 ? "#1e4028" : level >= 1 ? "#1a3020" : "#1a1c18"} />
                            <stop offset="100%" stopColor={level >= 2 ? "#162818" : "#0f1210"} />
                        </linearGradient>
                        <linearGradient id="water-grad" x1="0" y1="0" x2="1" y2="0">
                            <stop offset="0%" stopColor="#1a5a6e" />
                            <stop offset="50%" stopColor="#2a8a9e" />
                            <stop offset="100%" stopColor="#1a5a6e" />
                        </linearGradient>
                        <filter id="glow-f">
                            <feGaussianBlur stdDeviation="2" result="b" />
                            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                        <filter id="soft-glow">
                            <feGaussianBlur stdDeviation="4" result="b" />
                            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                    </defs>

                    {/* Sky */}
                    <rect width="400" height="225" fill="url(#sky-grad)" />

                    {/* Stars (level 2+) */}
                    {level >= 2 && stars.map((s, i) => (
                        <circle key={i} cx={s.x * 4} cy={s.y * 1.5} r={s.r} fill="white" opacity="0.5"
                            style={{ animationDelay: `${s.delay}s` }} className="star" />
                    ))}

                    {/* Moon/Sun glow */}
                    {level >= 1 && <circle cx="340" cy="30" r="24" fill="url(#sun-grad)" opacity="0.5" filter="url(#soft-glow)" />}
                    {level >= 1 && <circle cx="340" cy="30" r="12" fill={level >= 4 ? "#ffe87a" : level >= 2 ? "#ffd060" : "#ffb030"} opacity="0.7" />}

                    {/* Clouds (level 0 = grey overcast) */}
                    {level === 0 && <>
                        <ellipse cx="100" cy="55" rx="60" ry="22" fill="#2a2c28" opacity="0.7" />
                        <ellipse cx="200" cy="45" rx="80" ry="25" fill="#252824" opacity="0.8" />
                        <ellipse cx="320" cy="60" rx="55" ry="18" fill="#2a2c28" opacity="0.6" />
                    </>}
                    {level >= 2 && <>
                        <ellipse cx="80" cy="50" rx="35" ry="12" fill="rgba(255,255,255,0.04)" />
                        <ellipse cx="220" cy="42" rx="45" ry="14" fill="rgba(255,255,255,0.03)" />
                    </>}

                    {/* Ground */}
                    <path d="M0 155 Q100 145 200 155 Q300 165 400 155 L400 225 L0 225Z" fill="url(#ground-grad)" />

                    {/* Grass detail (level 1+) */}
                    {level >= 1 && Array.from({ length: 30 }, (_, i) => (
                        <line key={i} x1={i * 14 + 5} y1="155" x2={i * 14 + (i % 2 ? -3 : 3)} y2={145 - Math.sin(i) * 3}
                            stroke="#3a7a44" strokeWidth="1.5" opacity="0.7" />
                    ))}
                    {level >= 2 && Array.from({ length: 20 }, (_, i) => (
                        <line key={i} x1={i * 20 + 10} y1="158" x2={i * 20 + (i % 3 - 1) * 4} y2={148 - Math.cos(i) * 4}
                            stroke="#4a9a58" strokeWidth="1" opacity="0.5" />
                    ))}

                    {/* Stream (level 2+) */}
                    {level >= 2 && (
                        <path d="M30 175 Q80 168 140 172 Q200 176 260 170 Q310 165 370 168"
                            fill="none" stroke="url(#water-grad)" strokeWidth={level >= 3 ? 8 : 4}
                            strokeLinecap="round" opacity="0.8"
                            style={{ animation: 'stream-flow 3s linear infinite', strokeDasharray: 200, strokeDashoffset: 200 }} />
                    )}
                    {/* Pond (level 3+) */}
                    {level >= 3 && (
                        <ellipse cx="310" cy="178" rx="55" ry="18" fill="#1a6a7e" opacity="0.6" />
                    )}
                    {level >= 4 && (
                        <path d="M340 145 Q342 160 345 178" stroke="#4ab8ca" strokeWidth="3" strokeLinecap="round" fill="none" opacity="0.8" />
                    )}

                    {/* Withered sapling (level 0) */}
                    {level === 0 && <>
                        <line x1="200" y1="155" x2="200" y2="110" stroke="#3a3530" strokeWidth="3" />
                        <line x1="200" y1="130" x2="185" y2="120" stroke="#3a3530" strokeWidth="2" />
                        <line x1="200" y1="125" x2="215" y2="115" stroke="#3a3530" strokeWidth="2" />
                    </>}

                    {/* Shoots (level 1) */}
                    {level >= 1 && [60, 120, 180, 250, 320, 370].map((x, i) => (
                        <g key={i}>
                            <line x1={x} y1="155" x2={x + (i % 2 ? -4 : 4)} y2={140} stroke="#3a7a44" strokeWidth="2.5" />
                            <ellipse cx={x + (i % 2 ? -4 : 4)} cy={138} rx="5" ry="3" fill="#4a9a5a" transform={`rotate(${i * 15},${x + (i % 2 ? -4 : 4)},138)`} />
                        </g>
                    ))}

                    {/* Wildflowers (level 2+) */}
                    {level >= 2 && [
                        { x: 75, y: 152, c: '#e87a9e', r: 5 }, { x: 155, y: 149, c: '#a87adc', r: 4 }, { x: 225, y: 151, c: '#e8ca5a', r: 5 },
                        ...(level >= 3 ? [{ x: 290, y: 150, c: '#e87a9e', r: 4 }, { x: 350, y: 152, c: '#5ae87a', r: 5 }] : [])
                    ].map((f, i) => (
                        <g key={i} style={{ animation: `bloom 0.6s ${i * 0.1}s ease both` }}>
                            <line x1={f.x} y1={f.y} x2={f.x} y2={f.y + 16} stroke="#3a7a44" strokeWidth="1.5" />
                            {[0, 72, 144, 216, 288].map(a => (
                                <ellipse key={a} cx={f.x + Math.cos(a * Math.PI / 180) * f.r} cy={f.y + Math.sin(a * Math.PI / 180) * f.r}
                                    rx={f.r - 1} ry={f.r - 1} fill={f.c} opacity="0.85"
                                    transform={`rotate(${a},${f.x},${f.y})`} />
                            ))}
                            <circle cx={f.x} cy={f.y} r="2.5" fill="#ffe87a" />
                        </g>
                    ))}

                    {/* Tree (level 3+) */}
                    {level >= 3 && <>
                        <rect x="96" y="120" width="8" height="36" fill="#5a3a20" rx="2" />
                        <circle cx="100" cy="105" r="28" fill="#2a6a3a" opacity="0.9" />
                        <circle cx="88" cy="115" r="18" fill="#2a7a40" opacity="0.8" />
                        <circle cx="115" cy="110" r="20" fill="#2a6a38" opacity="0.8" />
                        {/* Blossoms */}
                        {level >= 3 && [[-15, -5], [10, -8], [0, 10], [-8, 8]].map(([dx, dy], i) => (
                            <circle key={i} cx={100 + dx} cy={105 + dy} r="3" fill="#e87aae" opacity="0.7" />
                        ))}
                    </>}

                    {/* Full tree + second tree (level 4) */}
                    {level >= 4 && <>
                        <rect x="294" y="118" width="6" height="34" fill="#5a3a20" rx="2" />
                        <circle cx="297" cy="106" r="22" fill="#3a8a4e" opacity="0.85" />
                        <circle cx="286" cy="114" r="14" fill="#3a9a56" opacity="0.8" />
                        <circle cx="310" cy="112" r="16" fill="#3a8a4a" opacity="0.8" />
                    </>}

                    {/* Wind Turbine(s) */}
                    {level >= 1 && <TurbineGroup x={340} y={100} scale={0.7} speed={level >= 2 ? 2 : 4} />}
                    {level >= 2 && <TurbineGroup x={50} y={110} scale={0.55} speed={3} />}

                    {/* Animals (level 3+) */}
                    {level >= 3 && <FoxSVG x={250} y={147} />}
                    {level >= 4 && <BirdSVG x={130} y={90} />}

                    {/* Bioluminescent plants (level 4) */}
                    {level >= 4 && [
                        { x: 170, y: 150, c: '#4aeac0' }, { x: 195, y: 148, c: '#7a9aea' }, { x: 210, y: 151, c: '#ea7aea' },
                        { x: 380, y: 152, c: '#4aeac0' }, { x: 25, y: 153, c: '#7aea9a' },
                    ].map((p, i) => (
                        <g key={i} filter="url(#glow-f)">
                            <line x1={p.x} y1={p.y} x2={p.x} y2={p.y + 10} stroke={p.c} strokeWidth="1.5" opacity="0.8" />
                            <circle cx={p.x} cy={p.y} r="4" fill={p.c} opacity="0.7" />
                        </g>
                    ))}

                    {/* Golden motes (level 4) */}
                    {level >= 4 && Array.from({ length: 8 }, (_, i) => (
                        <circle key={i} cx={40 + i * 45} cy={130 - i * 8} r="2" fill="#d4a843" opacity="0.8"
                            filter="url(#glow-f)"
                            style={{ animation: `mote-rise ${1.5 + i * 0.3}s ${i * 0.4}s ease-out infinite` }} />
                    ))}

                    {/* Carbon Debt shadow overlay */}
                    {hasDebt && (
                        <rect width="400" height="225" fill="#1a1a1a" opacity="0.28"
                            className="debt-shadow"
                            style={{ mixBlendMode: 'multiply' }} />
                    )}
                    {hasDebt && (
                        <path d="M-10 120 Q100 100 200 115 Q300 130 410 110 L410 230 L-10 230Z"
                            fill="#2a2a2a" opacity="0.22" className="debt-shadow" />
                    )}
