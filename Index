                                    <button className="simulate-witness-btn" onClick={handleSimulateWitness}>
                                        🧪 Simulate Friend Witness (Demo)
                                    </button>
                                </>}

                                {modal.step === 'fail' && <>
                                    <div style={{ textAlign: 'center', padding: '12px 0 8px' }}>
                                        <div style={{ fontSize: 48 }}>🌫️</div>
                                        <div className="modal-title" style={{ textAlign: 'center', marginTop: 8 }}>Couldn't Verify</div>
                                        <div style={{ fontSize: 13, color: 'var(--text-muted)', textAlign: 'center', marginTop: 6, lineHeight: 1.6 }}>
                                            Our AI couldn't confirm this action from the photo. Try a clearer image, or log it honestly as self-reported.
                                        </div>
                                    </div>
                                    <button className="witness-btn" style={{ marginTop: 16 }} onClick={() => setModal(null)}>Try Again</button>
                                </>}
                            </div>
                        </div>
                    )}
                </div>
            );
        }

