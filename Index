                                    <div style={{ marginTop: 16, textAlign: 'center', fontSize: 11, color: 'var(--text-muted)' }}>— OR —</div>

                                    <button className="witness-btn" style={{ marginTop: 12, background: 'transparent', border: '1px dashed var(--accent-green)', color: 'var(--accent-green)' }} onClick={() => setModal(m => ({ ...m, step: 'qr-scanner' }))}>
                                        🔍 Scan Partner QR Code
