        // ── LOG SCREEN ────────────────────────────────────────────────────────────
        function LogScreen({ profile, onLog }) {
            const [modal, setModal] = useState(null); // {type, step:'upload'|'analyzing'|'success'|'fail'|'witness', xpGained, witnessed}
            const [toast, setToast] = useState(null);
            const fileRef = useRef();
            const [uploadedFile, setUploadedFile] = useState(null);
            const [scanningQR, setScanningQR] = useState(false);

            const showToast = (msg, icon) => {
                setToast({ msg, icon });
                setTimeout(() => setToast(null), 3000);
            };

            const handlePrimary = (type) => {
                const cfg = STAT_CONFIGS[type];
                if (cfg.requiresImage) {
                    setModal({ type, step: 'upload' });
                } else {
                    logAction(type, true);
                }
            };

            const handleSecondary = (type) => {
                logAction(type, false);
            };

            const logAction = (type, positive) => {
                const xpGain = positive ? (10 + Math.floor(Math.random() * 6)) : 0;
                onLog(type, positive, xpGain, null, (result) => {
                    if (result.toastMsg) showToast(result.toastMsg, result.toastIcon);
                    else if (positive) setModal({ type, step: 'success', xpGained: result.xpGained, witnessed: false });
                });
            };

            const handleFileUpload = (type, file) => {
                if (!file) return;
                setUploadedFile(file);
                setModal({ type, step: 'analyzing' });
                // Mock AI analysis
                setTimeout(() => {
                    const isValid = Math.random() < 0.7;
                    const hash = `${file.name}_${file.size}_${file.lastModified}`;
                    const hashes = loadPhotoHashes();
                    const cat = hashes[type] || [];

                    if (cat.includes(hash)) {
                        setModal(null);
                        showToast('This moment\'s energy has already been honored today. Try something new!', '🌱');
                        return;
                    }

                    if (isValid) {
                        // First Discovery bonus
                        const isFirstDiscovery = !cat.some(h => h.startsWith(file.name));
                        const newHashes = { ...hashes, [type]: [...cat.slice(-2), hash] };
                        savePhotoHashes(newHashes);
                        const xpGain = 12 + (isFirstDiscovery ? 5 : 0) + Math.floor(Math.random() * 5);
                        onLog(type, true, xpGain, hash, (result) => {
                            setModal({ type, step: 'success', xpGained: result.xpGained, witnessed: false, firstDiscovery: isFirstDiscovery });
                        });
                    } else {
                        setModal({ type, step: 'fail' });
                    }
                }, 2200);
            };

            const handleSimulateWitness = () => {
                onLog(modal.type, true, 2, null, () => { });
                setModal(m => ({ ...m, witnessed: true }));
                showToast('+10% XP Bonus! You\'ve been witnessed! 👀', '✨');
            };

            return (
                <div className="tab-content">
                    {toast && <Toast msg={toast.msg} icon={toast.icon} />}
                    <div className="log-cards">
                        {Object.entries(STAT_CONFIGS).map(([key, cfg]) => {
                            const val = profile.stats[key];
                            const color = key === 'agility' ? '#4eca6e' : key === 'vitality' ? '#82ca6e' : key === 'purity' ? '#4ab8ca' : '#d4a843';
                            return (
                                <div className="log-card" key={key}>
                                    <div className="log-card-header">
                                        <div className="log-stat-info">
                                            <div className="log-stat-icon">{cfg.icon}</div>
                                            <div>
                                                <div className="log-stat-name">{cfg.label}</div>
                                                <div className="log-stat-val">{cfg.description}</div>
                                            </div>
                                        </div>
                                        <div className="log-stat-current" style={{ color }}>{val}</div>
                                    </div>
                                    <div style={{ height: 3, background: '#1a2a1e', borderRadius: 2, marginBottom: 12, overflow: 'hidden' }}>
                                        <div style={{ width: `${val}%`, height: '100%', background: color, borderRadius: 2, transition: 'width 0.5s', boxShadow: `0 0 6px ${color}60` }} />
                                    </div>
                                    <button className="log-primary-btn"
                                        style={{ background: `linear-gradient(135deg,${color}22,${color}15)`, border: `1px solid ${color}40`, color }}
                                        onClick={() => handlePrimary(key)}>
                                        {cfg.primary}
                                    </button>
                                    <button className="log-secondary-btn" onClick={() => handleSecondary(key)}>
                                        {cfg.secondary}
                                    </button>
                                </div>
                            );
                        })}
                    </div>

                    {/* MODAL */}
                    {modal && (
                        <div className="modal-overlay" onClick={e => { if (e.target.className === 'modal-overlay' && modal.step !== 'analyzing') setModal(null) }}>
                            <div className="modal-box">
                                <button className="modal-close" onClick={() => modal.step !== 'analyzing' && setModal(null)}>✕</button>

                                {modal.step === 'upload' && <>
                                    <div className="modal-title">{STAT_CONFIGS[modal.type].icon} Verify Your Action</div>
                                    <div className="modal-sub">Upload a photo so our AI can verify your eco-action.</div>
                                    <div className="file-upload-area" onClick={() => fileRef.current?.click()}>
                                        <input ref={fileRef} type="file" accept="image/*" onChange={e => handleFileUpload(modal.type, e.target.files[0])} />
